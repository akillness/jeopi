{
	"type": "module",
	"name": "jeopi-utils",
	"version": "16.2.28",
	"description": "Shared utilities for pi packages",
	"homepage": "https://github.com/akillness/jeopi",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akillness/jeopi.git",
		"directory": "packages/utils"
	},
	"bugs": {
		"url": "https://github.com/akillness/jeopi/issues"
	},
	"keywords": [
		"utilities",
		"cli",
		"logging",
		"streams"
	],
	"main": "./src/index.ts",
	"types": "./dist/types/index.d.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test --parallel",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"jeopi-natives": "catalog:",
		"handlebars": "catalog:",
		"winston": "catalog:",
		"winston-daily-rotate-file": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md",
		"dist/types"
	],
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./dist/types/*.d.ts",
			"import": "./src/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}
