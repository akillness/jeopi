{
	"type": "module",
	"name": "jeopi-stats",
	"version": "16.2.23",
	"description": "Local observability dashboard for pi AI usage statistics",
	"homepage": "https://github.com/akillness/jeopi",
	"author": "Can Boluk",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akillness/jeopi.git",
		"directory": "packages/stats"
	},
	"bugs": {
		"url": "https://github.com/akillness/jeopi/issues"
	},
	"keywords": [
		"ai",
		"observability",
		"metrics",
		"dashboard",
		"llm",
		"statistics"
	],
	"main": "./src/index.ts",
	"types": "./dist/types/index.d.ts",
	"bin": {
		"jeopi-stats": "./src/index.ts"
	},
	"scripts": {
		"gen:stats": "bun scripts/generate-client-bundle.ts --generate",
		"gen:stats:reset": "bun scripts/generate-client-bundle.ts --reset",
		"build": "bun run build.ts",
		"dev": "bun run src/index.ts",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit && tsgo -p tsconfig.client.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"jeopi-ai": "catalog:",
		"jeopi-catalog": "catalog:",
		"jeopi-utils": "catalog:",
		"@tailwindcss/node": "catalog:",
		"chart.js": "catalog:",
		"date-fns": "catalog:",
		"lucide-react": "catalog:",
		"react": "catalog:",
		"react-chartjs-2": "catalog:",
		"react-dom": "catalog:",
		"tailwindcss": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"postcss": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"build.ts",
		"tailwind.config.js",
		"README.md",
		"CHANGELOG.md",
		"dist/types",
		"dist/client"
	],
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./src/index.ts"
		},
		"./*": {
			"types": "./dist/types/*.d.ts",
			"import": "./src/*.ts"
		},
		"./client": {
			"types": "./dist/types/client/index.d.ts",
			"import": "./src/client/index.tsx"
		},
		"./client/*": {
			"types": "./dist/types/client/*.d.ts",
			"import": "./src/client/*.ts"
		},
		"./client/components/*": {
			"types": "./dist/types/client/components/*.d.ts",
			"import": "./src/client/components/*.ts"
		},
		"./*.js": "./src/*.ts"
	}
}
