{
	"type": "module",
	"name": "jeopi-collab-relay",
	"version": "0.1.0",
	"private": true,
	"description": "Self-hostable production relay for jeopi collab live sessions: WebSocket room forwarding, /share blob store, and the collab-web guest client, all behind one Bun server",
	"homepage": "https://github.com/akillness/jeopi",
	"author": "akillness",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akillness/jeopi.git",
		"directory": "packages/collab-relay"
	},
	"bugs": {
		"url": "https://github.com/akillness/jeopi/issues"
	},
	"keywords": [
		"collab",
		"relay",
		"websocket",
		"server"
	],
	"main": "./src/server.ts",
	"scripts": {
		"build": "bun scripts/build.ts",
		"dev": "bun run build && bun run start",
		"start": "bun src/server.ts",
		"test": "bun test --parallel",
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"jeopi-wire": "catalog:"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"scripts",
		"README.md",
		"CHANGELOG.md",
		"Dockerfile"
	]
}
